# Django Settings
# For production: DEBUG=False
# Generate a new SECRET_KEY using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DEBUG=False
SECRET_KEY=your-secret-key-here

# Database Configuration (using DATABASE_URL format)
# Local development: postgresql://postgres:password@localhost:5432/radoki_db
# Production (RDS/DigitalOcean/etc): postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/radoki_db

# Allowed hosts for production (comma-separated, no spaces)
# Development: localhost,127.0.0.1
# Production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF & Security Settings
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://*.yourdomain.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Cloudinary Configuration (for production media storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AWS/Media Storage (optional - for production)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Other Settings
ENVIRONMENT=production
